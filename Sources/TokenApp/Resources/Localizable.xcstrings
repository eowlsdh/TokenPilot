          "stringUnit": {
            "state": "translated",
            "value": "使用手动限额快照"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "手動上限スナップショットを使う"
          }
        }
      }
    },
    "Enter values you see on Codex web. TokenPilot stores only these numbers, not cookies or login tokens.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "직접 확인한 한도 값을 입력하세요. TokenPilot은 숫자만 저장하고 쿠키나 로그인 토큰은 저장하지 않습니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter limit values you saw yourself. TokenPilot stores only these numbers, not cookies or login tokens."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入你自己看到的限额值。TokenPilot 只保存这些数字，不保存 Cookie 或登录 Token。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分で確認した上限値を入力してください。TokenPilot は数値だけを保存し、Cookie やログイントークンは保存しません。"
          }
        }
      }
    },
