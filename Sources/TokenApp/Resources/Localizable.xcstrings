        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "手動 Codex 上限スナップショット"
          }
        }
      }
    },
    "Use Manual Limit Snapshot": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수동 한도 스냅샷 사용"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use Manual Limit Snapshot"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用手动限额快照"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "手動上限スナップショットを使う"
          }
        }
      }
    },
    "Enter manual values you observed. TokenPilot stores only numbers and notes, not cookies, login tokens, or raw account pages.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "직접 확인한 수동 값을 입력하세요. TokenPilot은 숫자와 메모만 저장하며 쿠키, 로그인 토큰, 원본 계정 페이지는 저장하지 않습니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter manual values you observed. TokenPilot stores only numbers and notes, not cookies, login tokens, or raw account pages."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入你观察到的手动值。TokenPilot 只保存数字和备注，不保存 Cookie、登录 Token 或原始账户页面。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分で確認した手動値を入力します。TokenPilot は数値とメモだけを保存し、Cookie、ログイントークン、生のアカウントページは保存しません。"
          }
        }
      }
    },
