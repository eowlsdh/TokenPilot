    "xAI is disabled by default. TokenPilot stores setup locally. No xAI HTTP requests are sent.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "xAI is disabled by default. TokenPilot stores setup locally. No xAI HTTP requests are sent."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "xAI는 기본적으로 비활성화됩니다. TokenPilot은 설정을 로컬에 저장하며 xAI HTTP 요청을 보내지 않습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "xAI はデフォルトで無効です。TokenPilot は設定をローカルに保存し、xAI HTTP リクエストを送信しません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "xAI 默认禁用。TokenPilot 在本地存储设置，不会发送 xAI HTTP 请求。"
          }
        }
      }
    },
    "xAI local setup presence": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "xAI local setup presence"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "xAI 로컬 설정 여부"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "xAI ローカル設定の有無"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "xAI 本地设置状态"
          }
        }
      }
    },
    "Team ID is stored locally and masked in summaries. Diagnostics and accessibility labels use presence only.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Team ID is stored locally and masked in summaries. Diagnostics and accessibility labels use presence only."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "팀 ID는 로컬에 저장되고 요약에서 마스킹됩니다. 진단과 손쉬운 사용 라벨에는 설정 여부만 표시됩니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チーム ID はローカルに保存され、概要ではマスクされます。診断とアクセシビリティラベルには設定の有無のみ表示します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "团队 ID 保存在本地，并在摘要中掩码。诊断和辅助功能标签仅显示是否已设置。"
          }
        }
      }
    },
    "A saved key plus team ID still means authentication unconfirmed. No xAI HTTP requests are sent; verify credentials outside TokenPilot.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A saved key plus team ID still means authentication unconfirmed. No xAI HTTP requests are sent; verify credentials outside TokenPilot."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "키와 팀 ID를 저장해도 인증은 미확인 상태입니다. xAI HTTP 요청은 보내지 않으므로 자격 증명은 TokenPilot 외부에서 확인하세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キーとチーム ID を保存しても認証は未確認です。xAI HTTP リクエストは送信しないため、認証情報は TokenPilot の外部で確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "即使已保存密钥和团队 ID，身份验证仍未确认。不会发送 xAI HTTP 请求；请在 TokenPilot 外部验证凭据。"
          }
        }
      }
    },
