    "Management key is saved in Keychain and team ID is stored locally. Authentication is unconfirmed. No xAI HTTP requests are sent.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Management key is saved in Keychain and team ID is stored locally. Authentication is unconfirmed. No xAI HTTP requests are sent."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Management 키는 Keychain에, 팀 ID는 로컬에 저장됩니다. 인증은 미확인 상태이며 xAI HTTP 요청은 보내지 않습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Management キーは Keychain に、チーム ID はローカルに保存されます。認証は未確認で、xAI HTTP リクエストは送信しません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Management 密钥保存在 Keychain，团队 ID 保存在本地。身份验证未确认，不会发送 xAI HTTP 请求。"
          }
        }
      }
    },
    "Save an xAI Management key in Keychain and a local team ID. Check Connection only checks local setup. No xAI HTTP requests are sent.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save an xAI Management key in Keychain and a local team ID. Check Connection only checks local setup. No xAI HTTP requests are sent."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "xAI Management 키를 Keychain에 저장하고 로컬 팀 ID를 입력하세요. 연결 확인은 로컬 설정만 검사하며 xAI HTTP 요청은 보내지 않습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "xAI Management キーを Keychain に保存し、ローカルのチーム ID を入力してください。接続確認はローカル設定のみを確認し、xAI HTTP リクエストは送信しません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请将 xAI Management 密钥保存到 Keychain，并输入本地团队 ID。检查连接只检查本地设置，不会发送 xAI HTTP 请求。"
          }
        }
      }
    },
    "Enable xAI only when you want local setup visibility.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable xAI only when you want local setup visibility."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 설정 상태를 확인할 때만 xAI를 활성화하세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカル設定を確認する場合のみ xAI を有効にしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在需要查看本地设置状态时启用 xAI。"
          }
        }
      }
    },
    "Authentication is unconfirmed; verify credentials outside TokenPilot.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentication is unconfirmed; verify credentials outside TokenPilot."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인증은 미확인 상태입니다. 자격 증명은 TokenPilot 외부에서 확인하세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "認証は未確認です。認証情報は TokenPilot の外部で確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "身份验证未确认；请在 TokenPilot 外部验证凭据。"
          }
        }
      }
    },
    "Enter a local team ID and save a Management key; Check Connection stays local.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a local team ID and save a Management key; Check Connection stays local."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 팀 ID를 입력하고 Management 키를 저장하세요. 연결 확인은 로컬에서만 동작합니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルのチーム ID を入力し、Management キーを保存してください。接続確認はローカルでのみ動作します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入本地团队 ID 并保存 Management 密钥；检查连接仅在本地运行。"
          }
        }
      }
    },
    "Enter an xAI Management key first.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter an xAI Management key first."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "먼저 xAI Management 키를 입력하세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "先に xAI Management キーを入力してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先输入 xAI Management 密钥。"
          }
        }
      }
    },
    "Menu bar data unavailable": {
      "localizations": {
