    "Effective Telegram delivery requires Global notifications, Telegram notifications, Telegram alerts, a saved bot token, and a chat ID.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "텔레그램 전달이 실제로 동작하려면 전체 알림, 텔레그램 알림, 텔레그램 경고, 저장된 봇 토큰, 채팅 ID가 필요합니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Effective Telegram delivery requires Global notifications, Telegram notifications, Telegram alerts, a saved bot token, and a chat ID."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram 实际投递需要全局通知、Telegram 通知、Telegram 提醒、已保存的机器人 Token 和聊天 ID。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram 配信を実効にするには、グローバル通知、Telegram 通知、Telegram アラート、保存済み Bot Token、Chat ID が必要です。"
          }
        }
      }
    },
    "Effective Discord delivery requires Global notifications, Discord notifications, Discord alerts, and a saved webhook.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디스코드 전달이 실제로 동작하려면 전체 알림, 디스코드 알림, 디스코드 경고, 저장된 Webhook이 필요합니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Effective Discord delivery requires Global notifications, Discord notifications, Discord alerts, and a saved webhook."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Discord 实际投递需要全局通知、Discord 通知、Discord 提醒和已保存的 Webhook。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Discord 配信を実効にするには、グローバル通知、Discord 通知、Discord アラート、保存済み Webhook が必要です。"
          }
        }
