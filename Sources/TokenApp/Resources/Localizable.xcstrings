    "Refresh provider health": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제공자 상태 새로고침"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Refresh provider health"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "刷新提供方健康"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロバイダ状態を更新"
          }
        }
      }
    },
    "Auto-detect checks local default metadata and user-selected files only. Diagnostics hide raw paths, raw events, prompts, responses, and secrets.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동 감지는 로컬 기본 메타데이터와 사용자가 선택한 파일만 확인합니다. 진단은 원본 경로, 원본 이벤트, 프롬프트, 응답, 비밀값을 숨깁니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto-detect checks local default metadata and user-selected files only. Diagnostics hide raw paths, raw events, prompts, responses, and secrets."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动检测只检查本地默认元数据和用户选择的文件。诊断会隐藏原始路径、原始事件、提示词、回复和密钥。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動検出はローカル既定メタデータとユーザー選択ファイルだけを確認します。診断では生パス、生イベント、プロンプト、応答、シークレットを隠します。"
          }
        }
      }
    },
    "Choose providers shown on Overview. Turning one off skips refresh without deleting stored history.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "개요에 표시할 제공자를 선택합니다. 끄면 저장된 기록을 삭제하지 않고 새로고침만 건너뜁니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose providers shown on Overview. Turning one off skips refresh without deleting stored history."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择概览中显示的提供方。关闭后会跳过刷新，但不会删除已存历史。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "概要に表示するプロバイダを選びます。オフにしても保存済み履歴は削除せず、更新だけをスキップします。"
          }
        }
      }
    },
    "Menu bar uses the core capacity assessment. Disabled providers are skipped.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메뉴바는 코어 수용량 평가를 사용합니다. 꺼진 제공자는 건너뜁니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Menu bar uses the core capacity assessment. Disabled providers are skipped."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "菜单栏使用核心容量评估。已关闭的提供方会被跳过。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メニューバーはコアの容量評価を使用します。無効なプロバイダはスキップします。"
          }
        }
      }
    },
    "Diagnostics summarize source health without showing raw local paths, raw events, prompts, responses, cookies, credentials, or tokens.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진단은 원본 로컬 경로, 원본 이벤트, 프롬프트, 응답, 쿠키, 자격 증명, 토큰을 보이지 않고 소스 상태를 요약합니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Diagnostics summarize source health without showing raw local paths, raw events, prompts, responses, cookies, credentials, or tokens."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "诊断会汇总来源健康，但不会显示原始本地路径、原始事件、提示词、回复、Cookie、凭据或 Token。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "診断は生のローカルパス、生イベント、プロンプト、応答、Cookie、認証情報、トークンを表示せずにソース状態を要約します。"
          }
        }
      }
    },
    "Claude status source": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude 상태 소스"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
