          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "実験的 Codex 上限ヒント"
          }
        }
      }
    },
    "Use experimental Codex limit hints": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "실험적 Codex 한도 힌트 사용"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use experimental Codex limit hints"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用实验性 Codex 限额提示"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "実験的 Codex 上限ヒントを使う"
          }
        }
      }
    },
    "Experimental connector asks the local Codex CLI app-server for account/rateLimits/read. TokenPilot never reads, stores, displays, or exports Codex access tokens.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "실험적 커넥터는 로컬 Codex CLI app-server에 account/rateLimits/read를 요청합니다. TokenPilot은 Codex access token을 읽거나 저장하거나 표시하거나 내보내지 않습니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Experimental connector asks the local Codex CLI app-server for account/rateLimits/read. TokenPilot never reads, stores, displays, or exports Codex access tokens."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "实验性连接器会向本地 Codex CLI app-server 请求 account/rateLimits/read。TokenPilot 绝不读取、保存、显示或导出 Codex access token。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "実験的コネクタはローカルの Codex CLI app-server に account/rateLimits/read を依頼します。TokenPilot は Codex アクセストークンを読み取り、保存、表示、書き出ししません。"
          }
        }
      }
    },
    "Codex limit hints are experimental and may break if the Codex CLI changes. They are not guaranteed official quota.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex 한도 힌트는 실험적이며 Codex CLI가 바뀌면 깨질 수 있습니다. 공식 한도 보장값이 아닙니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex limit hints are experimental and may break if the Codex CLI changes. They are not guaranteed official quota."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex 限额提示是实验性的，Codex CLI 变化时可能失效。它们不保证是官方配额。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Codex 上限ヒントは実験的で、Codex CLI が変わると壊れる可能性があります。公式上限を保証しません。"
          }
        }
      }
    },
    "Manual Codex limit snapshot": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수동 Codex 한도 스냅샷"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
