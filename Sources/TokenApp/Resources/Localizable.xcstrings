    },
    "Choose antigravity-statusline.json, legacy telemetry.log, or a session folder.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "antigravity-statusline.json, 레거시 telemetry.log 또는 세션 폴더를 선택하세요."
          }
        },
