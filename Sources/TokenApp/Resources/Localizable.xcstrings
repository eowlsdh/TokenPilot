            "value": "디스코드는 기본 꺼짐입니다. TokenPilot용으로 만든 디스코드 채널 Webhook만 붙여넣으세요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discord OFF by default. Paste only a Discord channel webhook created for TokenPilot."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
