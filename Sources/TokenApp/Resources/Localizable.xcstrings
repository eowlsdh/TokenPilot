    "Telegram OFF by default. Enable only after saving TokenPilot's own bot token.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "텔레그램은 기본 꺼짐입니다. TokenPilot 전용 봇 토큰을 저장한 뒤에만 켜세요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram OFF by default. Enable only after saving TokenPilot's own bot token."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram 默认关闭。请先保存 TokenPilot 专用机器人 Token 后再启用。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram は既定でオフです。TokenPilot 専用 Bot Token を保存してから有効にしてください。"
          }
        }
      }
    },
    "Telegram alerts are optional. TokenPilot stores only its own bot token Keychain item and sends only alert messages when enabled.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "텔레그램 알림은 선택 사항입니다. TokenPilot은 자체 봇 토큰 Keychain 항목만 저장하고, 켜진 경우 알림 메시지만 보냅니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram alerts are optional. TokenPilot stores only its own bot token Keychain item and sends only alert messages when enabled."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram 提醒是可选的。TokenPilot 只保存自己的机器人令牌 Keychain 项，启用后仅发送提醒消息。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram アラートは任意です。TokenPilot は自身のボットトークン Keychain 項目だけを保存し、有効時はアラートメッセージだけを送信します。"
          }
        }
      }
    },
