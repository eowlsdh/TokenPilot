    "Telegram alerts are optional. TokenPilot sends only alert messages when enabled.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "텔레그램 알림은 선택 사항입니다. 켜면 TokenPilot은 알림 메시지만 보냅니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram alerts are optional. TokenPilot sends only alert messages when enabled."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram 提醒是可选的。启用后 TokenPilot 只发送提醒消息。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Telegram通知は任意です。有効化時、TokenPilotは通知メッセージのみ送信します。"
          }
