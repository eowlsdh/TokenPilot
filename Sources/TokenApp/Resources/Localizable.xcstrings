    "You can select Antigravity statusline JSON, legacy Gemini telemetry.log, or a session folder.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity statusline JSON, 레거시 Gemini telemetry.log 또는 세션 폴더를 선택할 수 있습니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can select Antigravity statusline JSON, legacy Gemini telemetry.log, or a session folder."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可以选择 Antigravity statusline JSON、旧版 Gemini telemetry.log 或会话文件夹。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity statusline JSON、従来の Gemini telemetry.log、またはセッションフォルダを選択できます。"
          }
        }
      }
    },
    "Choose Antigravity source": {
      "localizations": {
