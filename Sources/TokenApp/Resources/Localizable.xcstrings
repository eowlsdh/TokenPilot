          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "TokenPilot は自身の DeepSeek APIキー Keychain 項目だけを保存し、公式 /user/balance エンドポイントだけを呼び出します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "TokenPilot 只保存自己的 DeepSeek API 密钥 Keychain 项，并调用官方 /user/balance 端点。"
