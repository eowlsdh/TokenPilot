    "Install the local statusLine bridge, then run Check Connection.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 statusLine 브리지를 설치한 뒤 연결 확인을 실행하세요."
          }
        },
        "en": {
