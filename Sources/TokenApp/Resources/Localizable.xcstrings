    "Refresh provider health": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제공자 상태 새로고침"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Refresh provider health"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "刷新提供方健康"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロバイダ状態を更新"
          }
        }
      }
    },
    "Auto-detect checks local default metadata and user-selected files only. Diagnostics hide raw paths, raw events, prompts, responses, and secrets.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동 감지는 로컬 기본 메타데이터와 사용자가 선택한 파일만 확인합니다. 진단은 원본 경로, 원본 이벤트, 프롬프트, 응답, 비밀값을 숨깁니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto-detect checks local default metadata and user-selected files only. Diagnostics hide raw paths, raw events, prompts, responses, and secrets."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动检测只检查本地默认元数据和用户选择的文件。诊断会隐藏原始路径、原始事件、提示词、回复和密钥。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動検出はローカル既定メタデータとユーザー選択ファイルだけを確認します。診断では生パス、生イベント、プロンプト、応答、シークレットを隠します。"
          }
        }
      }
    },
    "Choose providers shown on Overview. Turning one off skips refresh without deleting stored history.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "개요에 표시할 제공자를 선택합니다. 끄면 저장된 기록을 삭제하지 않고 새로고침만 건너뜁니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose providers shown on Overview. Turning one off skips refresh without deleting stored history."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择概览中显示的提供方。关闭后会跳过刷新，但不会删除已存历史。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "概要に表示するプロバイダを選びます。オフにしても保存済み履歴は削除せず、更新だけをスキップします。"
          }
        }
      }
    },
    "Menu bar uses the core capacity assessment. Disabled providers are skipped.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메뉴바는 코어 수용량 평가를 사용합니다. 꺼진 제공자는 건너뜁니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Menu bar uses the core capacity assessment. Disabled providers are skipped."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "菜单栏使用核心容量评估。已关闭的提供方会被跳过。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メニューバーはコアの容量評価を使用します。無効なプロバイダはスキップします。"
          }
        }
      }
    },
    "Diagnostics summarize source health without showing raw local paths, raw events, prompts, responses, cookies, credentials, or tokens.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진단은 원본 로컬 경로, 원본 이벤트, 프롬프트, 응답, 쿠키, 자격 증명, 토큰을 보이지 않고 소스 상태를 요약합니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Diagnostics summarize source health without showing raw local paths, raw events, prompts, responses, cookies, credentials, or tokens."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "诊断会汇总来源健康，但不会显示原始本地路径、原始事件、提示词、回复、Cookie、凭据或 Token。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "診断は生のローカルパス、生イベント、プロンプト、応答、Cookie、認証情報、トークンを表示せずにソース状態を要約します。"
          }
        }
      }
    },
    "Claude status source": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude 상태 소스"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude status source"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude 状态来源"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude 状態ソース"
          }
        }
      }
    },
    "Raw local paths stay hidden. Choose again to replace the saved source bookmark.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "원본 로컬 경로는 숨겨집니다. 저장된 소스 북마크를 바꾸려면 다시 선택하세요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Raw local paths stay hidden. Choose again to replace the saved source bookmark."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "原始本地路径会保持隐藏。重新选择可替换已保存的来源书签。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "生のローカルパスは表示しません。保存済みソースブックマークを置き換えるには選び直してください。"
          }
        }
      }
    },
    "Antigravity telemetry source": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity 텔레메트리 소스"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity telemetry source"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity 遥测来源"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity telemetry ソース"
          }
        }
      }
    },
    "Select statusline JSON, legacy telemetry, or a session folder. Raw local paths stay hidden after selection.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "statusline JSON, 레거시 텔레메트리 또는 세션 폴더를 선택하세요. 선택 후에도 원본 로컬 경로는 숨겨집니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select statusline JSON, legacy telemetry, or a session folder. Raw local paths stay hidden after selection."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 statusline JSON、旧版遥测或会话文件夹。选择后原始本地路径仍会隐藏。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "statusline JSON、従来の telemetry、またはセッションフォルダを選択します。選択後も生のローカルパスは隠します。"
          }
        }
      }
    },
    "Experimental Codex limit hints": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "실험적 Codex 한도 힌트"
          }
        },
