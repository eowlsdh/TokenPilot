          }
        }
      }
    },
    "Parsed status remains manual or estimated unless the source is provider-reported and fresh.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "소스가 제공자 보고이면서 최신이 아닌 한 파싱된 상태는 수동 또는 추정으로 유지됩니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Parsed status remains manual or estimated unless the source is provider-reported and fresh."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "除非来源为提供方报告且新鲜，解析后的状态仍会标记为手动或估计。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ソースがプロバイダ報告かつ新鮮でない限り、解析済み状態は手動または推定のままです。"
          }
        }
      }
    },
    "Global OFF disables every channel. Channel OFF disables matching alert-rule delivery controls.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전체가 꺼지면 모든 채널이 꺼집니다. 채널이 꺼지면 해당 알림 규칙 전달 컨트롤도 비활성화됩니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Global OFF disables every channel. Channel OFF disables matching alert-rule delivery controls."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "全局关闭会禁用所有渠道。渠道关闭会禁用对应的告警规则投递控件。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "グローバルがオフなら全チャンネルが無効です。チャンネルがオフなら対応する通知ルールの配信操作も無効です。"
          }
        }
      }
    },
