    "xAI is disabled by default. Enable it only when you want local setup visibility.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "xAI is disabled by default. Enable it only when you want local setup visibility."
          }
        },
        "ko": {
