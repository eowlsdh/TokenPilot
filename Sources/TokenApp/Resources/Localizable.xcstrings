      }
    },
    "Raw local paths stay hidden. Choose again to replace the saved source bookmark.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "원본 로컬 경로는 숨겨집니다. 저장된 소스 북마크를 바꾸려면 다시 선택하세요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Raw local paths stay hidden. Choose again to replace the saved source bookmark."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "原始本地路径会保持隐藏。重新选择可替换已保存的来源书签。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "生のローカルパスは表示しません。保存済みソースブックマークを置き換えるには選び直してください。"
          }
        }
      }
    },
    "Antigravity telemetry source": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity 텔레메트리 소스"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity telemetry source"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity 遥测来源"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Antigravity telemetry ソース"
          }
        }
      }
    },
    "Select statusline JSON, legacy telemetry, or a session folder. Raw local paths stay hidden after selection.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "statusline JSON, 레거시 텔레메트리 또는 세션 폴더를 선택하세요. 선택 후에도 원본 로컬 경로는 숨겨집니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select statusline JSON, legacy telemetry, or a session folder. Raw local paths stay hidden after selection."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 statusline JSON、旧版遥测或会话文件夹。选择后原始本地路径仍会隐藏。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
