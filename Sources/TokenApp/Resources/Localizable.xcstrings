          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "実験的 Codex 上限ヒント"
          }
        }
      }
    },
    "Use experimental Codex limit hints": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "실험적 Codex 한도 힌트 사용"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use experimental Codex limit hints"
          }
        },
